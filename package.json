{
  "name": "cn-hackathon-darkpools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend",
    "canton-connect-kit"
  ],
  "overrides": {
    "@canton-network/dapp-sdk": "1.1.0",
    "@canton-network/core-provider-dapp": "1.4.0",
    "@canton-network/core-rpc-transport": "1.4.0",
    "@canton-network/core-splice-provider": "1.4.0",
    "@canton-network/core-types": "1.4.0",
    "@canton-network/core-wallet-dapp-remote-rpc-client": "1.4.0",
    "@canton-network/core-wallet-dapp-rpc-client": "1.4.0",
    "@canton-network/core-wallet-discovery": "1.4.0",
    "@canton-network/core-wallet-ui-components": "1.4.0"
  },
  "scripts": {
    "backend:dev": "npm --prefix backend run dev",
    "backend:test": "npm --prefix backend test",
    "backend:build": "docker compose build dark-pool-backend",
    "backend:up": "docker compose up -d --build dark-pool-backend",
    "backend:down": "docker compose down",
    "backend:logs": "docker logs -f -n=300 dark-pool-backend",
    "app:dev": "npm --prefix frontend run dev -- --host localhost --port 3012 --strictPort",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  }
}
