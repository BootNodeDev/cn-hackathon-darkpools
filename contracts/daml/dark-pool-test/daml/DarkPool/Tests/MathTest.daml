module DarkPool.Tests.MathTest where

import DA.Assert ((===))
import Daml.Script
import DarkPool.Math

mathRoundingTest : Script ()
mathRoundingTest = do
  -- midpoint: exact when the sum halves cleanly
  midpointPrice 10.0 8.0 === 9.0
  -- 0.0000000001 + 0.0000000002 = 0.0000000003; /2 = 0.00000000015 -> floor 0.0000000001
  midpointPrice 0.0000000002 0.0000000001 === 0.0000000001
  -- quoteAmount: 0.3333333333 * 0.3 = 0.09999999999 exact -> floor at 10dp
  quoteAmount 0.3333333333 0.3 === 0.0999999999
  -- half-even on that same product would give 0.1000000000; we must differ
  assertMsg "floor differs from banker's rounding here" (quoteAmount 0.3333333333 0.3 /= 0.1)
  -- exact products are untouched
  quoteAmount 2.0 1.5 === 3.0
  quoteAmount 1000000.0 0.0000000001 === 0.0001

mathDomainTest : Script ()
mathDomainTest = do
  crosses 10.0 9.0 === True
  crosses 10.0 10.0 === True      -- equal limits cross; midpoint = the common price
  crosses 9.0 10.0 === False
  fillQuantity 5.0 3.0 === 3.0
  fillQuantity 3.0 5.0 === 3.0
  -- remainder recreated only if it can still satisfy minFill
  remainderQuantity 10.0 4.0 2.0 === Some 6.0
  remainderQuantity 10.0 9.0 2.0 === None     -- tail 1.0 < minFill 2.0
  remainderQuantity 10.0 10.0 2.0 === None    -- full fill
  remainderQuantity 10.0 8.0 2.0 === Some 2.0 -- tail exactly minFill survives
  -- sent amounts per side
  sentAmount Buy 4.0 9.0 === 36.0             -- buyer sends quote = qty * price (floored)
  sentAmount Sell 4.0 9.0 === 4.0             -- seller sends base = qty
  -- buyer worst-case funding bound dominates any execPrice <= limit
  assertMsg "funding bound dominates"
    (buyFundingTarget 7.0 11.5 >= sentAmount Buy 7.0 (midpointPrice 11.5 10.0))
  -- price-within-limit predicate
  priceWithinLimit Buy 9.0 10.0 === True
  priceWithinLimit Buy 10.1 10.0 === False
  priceWithinLimit Sell 9.0 10.0 === False
  priceWithinLimit Sell 10.1 10.0 === True
